	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"lefthook": "^2.1.9",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3"
	},
	"allowScripts": {
		"esbuild@0.28.1": true,
		"lefthook@2.1.9": true,
		"sharp@0.34.5": true
